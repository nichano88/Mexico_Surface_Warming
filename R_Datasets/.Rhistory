load("/Users/nico/Desktop/Senior_Thesis/R_Datasets/aod_yearly_from_nc.RData")
################ AOD year averages####################
load("/Users/nico/Desktop/Senior_Thesis/R_Datasets/aod_from_nc.RData")
nlon <- length(aod$lon) # number of longitude indexes to pass through (576)
nlat <- length(aod$lat) # number of latitude indexes to pass through (361)
n <- length(aod$time) # number of time indexes to pass through (548)
yr <- seq(1980, 2025, 1) #1970:2025 # years we care about as a sequence
#Establish 3D array in order to store annual average values for each grid cell
yr_aod = array(data=NA,dim=c(nlon, nlat,length(yr)))
for (i in 1:nlon){ #loop through all longitude vals
for (j in 1:nlat){ #loop through all latitude vals
for (k in 1:length(yr)){ #loop through each year from 1970:2024
tmp = aod$AODANA[i, j, ] #assigning our space-time data to a temporary var
index = floor(aod$time) == yr[k] #logical statement that provides an index number that corresponds time to the appropriate year
yr_aod[i, j, k] = mean(tmp[index], na.rm = TRUE) #Add the yearly anomalies to our 3D array
}
if(j %% 361 == 0){
total_processed = (i-1)*length(aod$lat) + j
total_cells = length(aod$lon) * length(aod$lat)
progress = round(100 * total_processed / total_cells, 1)
cat("Progress:", progress, "% [Lon", i, ", Lat", j, "] ", "\n")
}
}
}
