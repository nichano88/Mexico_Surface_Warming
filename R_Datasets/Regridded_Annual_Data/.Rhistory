correlation = corARMA(p=1, q=1, form = ~ year),
method ="ML", na.action = na.exclude)
coefficients(model.a)
coefficients(model.c)
df<-df %>% mutate(
model.c.predictions = predictSE.gls (model.b, newdata = df, se.fit=T)$fit,
model.c.se = predictSE.gls (model.b, df, se.fit=T)$se
)
ggplot(df,aes(year,TAS))+
geom_ribbon(aes(ymin = model.c.predictions - (1.96*model.c.se), ymax = model.c.predictions + (1.96*model.c.se)), fill = "pink")+
geom_line(aes(year,model.c.predictions),color="red",lty=2)+
geom_ribbon(aes(ymin = model.b.predictions - (1.96*model.b.se), ymax = model.b.predictions + (1.96*model.b.se)), fill = "lightgreen")+
geom_line(aes(year,model.b.predictions),color="black",lty=1)+
geom_point(alpha=0.5)
####Finally Calculate the relative differences at the different time points
####Between AR(1) model and the counterfactual
format(df$model.b.predictions-df$model.c.predictions,scientific = F)[c(1,29,30,46)]
#Green ribbon → 95% confidence interval
#Clear slope change at 2010 → the core ITS result
#'The interrupted time series analysis shows
#'that temperatures at this location followed
#'a relatively weak trend before 2010, but the
#'warming rate increased substantially afterward.
#'There is little evidence of an abrupt jump at the break year,
#'indicating that the main change is a post‑2010 acceleration in
#'the underlying trend rather than a sudden shift. Together, the model supports 2010 as a transition point marking the onset of a faster warming regime
# Extract slope values
pre_slope <- coef(model.a)["year"]
slope_diff <- coef(model.a)["Post.intervention.time"]
post_slope <- pre_slope + slope_diff
####NOW Develop the Counter factual Model####
df2 <- df
df_cf$Post.intervention.time <- 0   # counterfactual = no slope change after 2010
df <- df %>% mutate(
model.c.predictions = predictSE.gls(model.b, newdata = df_cf, se.fit = TRUE)$fit,
model.c.se = predictSE.gls(model.b, newdata = df_cf, se.fit = TRUE)$se
)
ggplot(df,aes(year,TAS))+
geom_ribbon(aes(ymin = model.c.predictions - (1.96*model.c.se), ymax = model.c.predictions + (1.96*model.c.se)), fill = "pink")+
geom_line(aes(year,model.c.predictions),color="red",lty=2)+
geom_ribbon(aes(ymin = model.b.predictions - (1.96*model.b.se), ymax = model.b.predictions + (1.96*model.b.se)), fill = "lightgreen")+
geom_line(aes(year,model.b.predictions),color="black",lty=1)+
geom_point(alpha=0.5)
####Finally Calculate the relative differences at the different time points
####Between AR(1) model and the counterfactual
format(df$model.b.predictions-df$model.c.predictions,scientific = F)[c(1,29,30,46)]
