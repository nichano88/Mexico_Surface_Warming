# Test 2: assume [lat, lon, time]
range(yr_tas[mex_lat[1], mex_lon[1], ], na.rm = TRUE)
# Test 3: assume [lon, time, lat]
range(yr_tas[mex_lon[1], , mex_lat[1]], na.rm = TRUE)
