##########################################
#This file will be used to develop an ITS
#Analysis for the Surface Temp Anomaly
##########################################
library(nlme)
library(DT)
library(AICcmodavg)
library(stringr)
ITS_analysis <- function(x,y,time,data){
df <- tibble(
year = time,
Post.intervention.time = c(rep(0,30),1:16),
TAS = data[x, y, ]
)
### Fit ITS ARMA(1,1)
model.b <- try(gls(
TAS ~ year + Post.intervention.time,
data = df,
correlation = corARMA(p=1, q=1, form = ~ year),
method = "ML",
na.action = na.exclude
), silent = TRUE)
if(inherits(model.b, "try-error")) return(NA)
#Factual Predictions
df$factual <- predict(model.b)
#Counter-Factual Predictions
df_cf <- df
df_cf$Post.intervention.time <- 0
df$counterfactual <- predict(model.b, newdata = df_cf)
#Difference at Final Timesetp (2025)
diff_2025 <- df$factual[46] - df$counterfactual[46]
}
dim(data)
dim(yr_tas)
