lon = aod$lon, lat = aod$lat, nlon, nlat, n, yr, yr_aod)
lon = aod$lon
lat = aod$lat
save(file = "/Users/nico/Desktop/Senior_Thesis/R_Datasets/aod_yearly_from_nc.RData",
lon, lat, nlon, nlat, n, yr, yr_aod)
