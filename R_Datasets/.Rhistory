#' @param chosen_dataset 3D array (lon x lat x time)
#'
#' @return List with regridded data array (360 x 180 x time) and coordinate vectors
# Define target grid
target_lat <- seq(from = -89.5, by = 1, to = 89.5)
target_lon <- seq(from = -179.5, by = 1, to = 179.5)
ntime <- dim(chosen_dataset)[3]
cat("Input dimensions:", dim(chosen_dataset)[1], "x", dim(chosen_dataset)[2], "x", ntime, "\n")
# Create multi-layer raster
raster_list <- list()
cat("Creating raster stack...\n")
for (t in 1:ntime) {
slice_2d <- chosen_dataset[, , t]
# terra uses (row, col) = (lat, lon), so transpose
r <- rast(t(slice_2d),
extent = ext(min(lon), max(lon), min(lat), max(lat)),
crs = "epsg:4326")
raster_list[[t]] <- r
if (t %% 10 == 0) {
cat("  Layer", t, "/", ntime, "\n")
}
}
# Stack all layers
r_stack <- rast(raster_list)
# Create target raster (180 rows, 360 cols)
target_raster <- rast(nrow = 180, ncol = 360,
extent = ext(-180, 180, -90, 90),
crs = "epsg:4326",
nlyr = ntime)
# Resample all layers at once
cat("Resampling to 1x1 degree grid...\n")
regridded_raster <- resample(r_stack, target_raster, method = "average")
# Convert to array with proper dimensions
cat("Converting to array...\n")
regridded_array <- array(NA, dim = c(360, 180, ntime))
for (t in 1:ntime) {
regridded_matrix <- as.matrix(regridded_raster[[t]], wide = TRUE)
# Transpose to get (lon x lat)
regridded_array[, , t] <- t(regridded_matrix)
}
cat("Output dimensions:", dim(regridded_array)[1], "x", dim(regridded_array)[2], "x", dim(regridded_array)[3], "\n")
cat("Regridding complete! Final: 360 (lon) x 180 (lat) x", ntime, "(time)\n")
return(list(
data = regridded_array,
lon = target_lon,
lat = target_lat,
time = time
))
}
