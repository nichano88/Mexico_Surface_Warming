##########################################
#This file will be used to develop an ITS
#Analysis for the Surface Temp Anomaly
##########################################
library(nlme)
library(DT)
library(AICcmodavg)
library(stringr)
load("/Users/nicochavez/Desktop/Senior_Thesis/R_Datasets/Regridded_Annual_Data/tas_yearly_from_nc.RData")
#Selecting Lon/Lat Values
lat_index <- which.min(abs(lon - (-90))) #90W
lon_index <- which.min(abs(lat - 18)) #18N
df<-tibble(
year = yr, #  A number, the year in observations
#Intervention = c(rep(0,30),rep(1,16)), # A binary indication of whether the Intervention has taken place at Time x
Post.intervention.time = c(rep(0,30),1:16), # A number, the time elapsed since the Intervention
TAS = (yr_tas[lat_index,lon_index, ])
) # The thing we want to measure
model.a = gls(TAS ~ year + Post.intervention.time, data = df, method="ML", na.action = na.exclude)
# Show a summary of the model
summary(model.a)
df<-df %>% mutate(
model.a.predictions = predictSE.gls (model.a, df, se.fit=T)$fit,
model.a.se = predictSE.gls (model.a, df, se.fit=T)$se
)
ggplot(df,aes(year,TAS))+
geom_ribbon(aes(ymin = model.a.predictions - (1.96*model.a.se), ymax = model.a.predictions + (1.96*model.a.se)), fill = "lightgreen")+
geom_line(aes(year,model.a.predictions),color="black",lty=1)+
geom_point(alpha=0.5)
mod.1 = TAS ~ year + Post.intervention.time
fx = function(pval,qval){summary(gls(mod.1, data = df,
correlation = corARMA(p=pval, q=qval, form = ~ year),
method="ML", na.action = na.exclude))$AIC}
p = summary(gls(mod.1, data = df, method ="ML", na.action = na.exclude))$AIC
message(str_c ("AIC Uncorrelated mdoel = ", p))
autocorrel = expand.grid(pval = 0:1, qval = 0:1)
#skip over 0,0 combination which is essentially our model A
for(i in 2:nrow(autocorrel)){p[i] = try(summary(gls(mod.1, data = df,
correlation= corARMA(p=autocorrel$pval[i],q=autocorrel$qval[i],
form = ~ year),method="ML",na.action = na.exclude))$AIC)}
autocorrel<- autocorrel %>%
mutate(AIC = as.numeric(p)) %>%
arrange(AIC)
autocorrel
model.b = gls(TAS ~ year + Post.intervention.time,
data = df, method ="ML",
correlation = corARMA(p=1,q=1, form= ~ year),
na.action = na.exclude)
coefficients(model.a)
coefficients(model.b)
####ADD Model B to df####
df<- df %>%
mutate(
model.b.predictions = predictSE.gls (model.b, df, se.fit=T)$fit,
model.b.se = predictSE.gls (model.b, df, se.fit=T)$se
)
####NOW Develop the Counter factual Model####
df2 <- df
df2$Post.intervention.time <- 0   # counterfactual = no slope change after 2010
df <- df %>% mutate(
model.c.predictions = predictSE.gls(model.b, newdata = df2, se.fit = TRUE)$fit,
model.c.se = predictSE.gls(model.b, newdata = df2, se.fit = TRUE)$se
)
ggplot(df,aes(year,TAS))+
geom_ribbon(aes(ymin = model.c.predictions - (1.96*model.c.se), ymax = model.c.predictions + (1.96*model.c.se)), fill = "pink")+
geom_line(aes(year,model.c.predictions),color="red",lty=2)+
geom_ribbon(aes(ymin = model.b.predictions - (1.96*model.b.se), ymax = model.b.predictions + (1.96*model.b.se)), fill = "lightgreen")+
geom_line(aes(year,model.b.predictions),color="black",lty=1)+
geom_point(alpha=0.5)
####Finally Calculate the relative differences at the different time points
####Between AR(1) model and the counterfactual
format(df$model.b.predictions-df$model.c.predictions,scientific = F)[c(1,29,30,46)]
